// This is your Prisma schema file
// Uses SQLite in dev, PostgreSQL in production (swap via DATABASE_URL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  nameEn        String?
  description   String
  descriptionEn String?
  priceOre      Int
  images        String   // JSON array stored as string for SQLite compat
  category      String
  stock         Int      @default(0)
  material      String
  dimensionsMm  String
  weightGrams   Int?
  featured      Boolean  @default(false)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Order {
  id              String   @id @default(cuid())
  stripeSessionId String   @unique
  email           String
  items           String   // JSON snapshot
  subtotalOre     Int
  shippingOre     Int
  totalOre        Int
  paymentMethod   String?
  status          String   @default("pending")
  shippingAddress String?  // JSON
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
