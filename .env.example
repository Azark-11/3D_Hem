# Next.js runtime reads this file (.env.local) at dev/build time.
# Prisma CLI reads .env instead. For local dev, create a minimal .env
# with just DATABASE_URL so `prisma migrate dev` / `prisma db seed` work.
# Never put secrets in .env — keep those here in .env.local only.

DATABASE_URL="file:./dev.db"
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PAYMENT_METHOD_CONFIGURATION=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=
IMAGE_PROVIDER=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
SHIPPING_FLAT_ORE=4900
DEFAULT_LOCALE=sv
